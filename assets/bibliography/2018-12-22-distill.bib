   author = {Akcelik-Deveci, S. and Kilic, E. and Mansur-Ozen, N. and Timucin, E. and Buyukcolak, Y. and Oktem-Okullu, S.},
   title = {Identification of interaction partners of outer inflammatory protein A: Computational and experimental insights into how Helicobacter pylori infects host cells},
   journal = {PLoS One},
   volume = {19},
   number = {10},
   pages = {e0300557},
   note = {Akcelik-Deveci, Sumeyye
Kilic, Elif
Mansur-Ozen, Nesteren
Timucin, Emel

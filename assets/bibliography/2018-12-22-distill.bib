@article{
   author = {Sardag, I. and Duvenci, Z. S. and Belkaya, S. and Timucin, E.},
   title = {Rational design of monomeric IL37 variants guided by stability and dynamical analyses of IL37 dimers},
   journal = {Comput Struct Biotechnol J},

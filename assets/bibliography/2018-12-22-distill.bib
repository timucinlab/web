   author = {Erbil, S. and Oral, O. and Mitou, G. and Kig, C. and Durmaz-Timucin, E. and Guven-Maiorov, E. and Gulacti, F. and Gokce, G. and Dengjel, J. and Sezerman, O. U. and Gozuacik, D.},
